# Anthropic Claude APIキー（和訳・要約の日本語生成に使用）
# https://console.anthropic.com/settings/keys で取得（sk-ant- で始まる）
ANTHROPIC_API_KEY=your-key-here

# 任意: 使用するモデル名（省略時は claude-haiku-4-5-20251001）
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# 任意: AIによる論文ランキングを有効化（省略時はキーワード順）
# CLAUDE_AI_RANKING=false

# メール送信（SMTP設定のみ .env に記載。送信先は画面で毎回入力）
# Gmail: 2段階認証を有効にし、アプリパスワードを SMTP_PASSWORD に設定
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=your-email@gmail.com
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# MAIL_SUBJECT=医学論文検索結果
